{
  "name": "hordee",
  "version": "1.0.0",
  "description": "Hordee - Dormitory Management System",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "db:migrate": "prisma migrate dev",
